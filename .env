PORT=5000
JWT_SECRET=replace_this_with_a_secure_random_string_before_deploying
NODE_ENV=development

# Database Dialect: 'sqlite' or 'mysql'
DB_DIALECT=sqlite
DB_STORAGE=./cms.sqlite

# MySQL Configurations (if DB_DIALECT=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=apexcms_db
DB_USER=root
DB_PASSWORD=
